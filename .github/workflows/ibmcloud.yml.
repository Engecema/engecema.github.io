      - name: Instalar dependencias do Cloudant
        run: npm install @ibm-cloud/cloudant ibm-cloud-sdk-core

      - name: Executar Teste de Conexao
        run: node test-db.js
        env:
          CLOUDANT_API_KEY: ${{ secrets.CLOUDANT_API_KEY }}
